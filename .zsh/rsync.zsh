alias rsync_backup="rsync -aAXHvP --delete \
  --exclude='/dev/*' \
  --exclude='/proc/*' \
  --exclude='/sys/*' \
  --exclude='/tmp/*' \
  --exclude='/run/*' \
  --exclude='/mnt/*' \
  --exclude='/media/*' \
  --exclude='/var/cache/*' \
  --exclude='/var/tmp/*' \
  --exclude='/var/run/*' \
  --exclude='/var/lock/*' \
  --exclude='/var/lib/docker/*' \
  --exclude='/lost+found/' "
